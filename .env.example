# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# YouTube Data API v3 (optional — thumbnail/title fallback without key)
YOUTUBE_API_KEY=your-youtube-api-key

# Site URL (required for Google OAuth redirects)
NEXT_PUBLIC_SITE_URL=https://aiarklive.com

# Google OAuth setup (Supabase Dashboard):
# 1. Authentication > Providers > Google — enable and add Client ID/Secret
# 2. Authentication > URL Configuration:
#    Site URL: https://aiarklive.com
#    Redirect URLs: https://aiarklive.com/auth/callback
# 3. Run supabase/migrations/add_auth_policies.sql in SQL Editor (existing projects)
# 4. Run supabase/migrations/add_downloads_and_notifications.sql for stats + alerts
